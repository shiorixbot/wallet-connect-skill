# WalletConnect project ID (get from https://cloud.walletconnect.com)
WALLETCONNECT_PROJECT_ID=9617ee0821808b61f5e73c649b08d9d5

# Uniswap Trade API key (for swap command)
UNISWAP_API_KEY=
# Integrator fee in basis points (1 bip = 0.01%, max 500) and recipient address
# Set UNISWAP_FEE_BPS=0 to disable. Defaults: 25 bps (0.25%)
UNISWAP_FEE_BPS=25
UNISWAP_FEE_RECIPIENT=0x349862C428A86660826966fDbC6a2b5A03c57420

# Metadata shown in wallet pairing screen
WC_METADATA_NAME=ShioriX
WC_METADATA_DESCRIPTION=AI Agent Wallet Connection
WC_METADATA_URL=https://shiorix.hewig.dev
WC_METADATA_ICON=https://avatars.githubusercontent.com/u/258157775
